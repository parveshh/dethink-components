{
  "name": "@dethink/components",
  "version": "0.0.0",
  "description": "Open-code React components for production dashboards, internal tools, and AI-native applications.",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./src/styles.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:a11y": "vitest run src/foundation/*.a11y.test.tsx src/components/*/*.a11y.test.tsx"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "clsx": "^2.1.1",
    "react-aria-components": "^1.19.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
